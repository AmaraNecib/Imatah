<script>
    let articleWraprer = document.querySelector('article #body-text');
    if(articleWraprer){
        var teadAdDiv1 = document.createElement('div');
        teadAdDiv1.classList.add('teadsad1');
        var teadAdDiv2 = document.createElement('div');
        teadAdDiv2.classList.add('teadsad2');
        let nodeListOf = articleWraprer.querySelectorAll("p");
        if(nodeListOf.length>0){
            if(nodeListOf.length>1){
                articleWraprer.insertBefore(teadAdDiv1, nodeListOf[1].nextSibling);
            }
            let lastFth=nodeListOf.length>7? 7 : (nodeListOf.length - 1);
            articleWraprer.insertBefore(teadAdDiv2, nodeListOf[lastFth].nextSibling);
        }
    }

    const scrnWidth=window.screen.availWidth;
    let teadTagElem = document.querySelector('.teads-wrapper');
    if(teadTagElem){
        let teadTag=teadTagElem.dataset.mobTag;
        if(scrnWidth>1199){
            teadTag=teadTagElem.dataset.desktopTag;
        }else if (scrnWidth>500){
            teadTag=teadTagElem.dataset.tabletTag;
        }
        var my_awesome_script = document.createElement('script');
        my_awesome_script.setAttribute('src','//a.teads.tv/page/'+teadTag+'/tag');
        my_awesome_script.setAttribute('async','true');
        teadTagElem.parentNode.insertBefore(my_awesome_script, teadTagElem.nextSibling);
    }
</script>

